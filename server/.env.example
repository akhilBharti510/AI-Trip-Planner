# ==============================================================================
# Server Environment Variable Configuration Template
# Instructions: Copy this file to '.env' in the same folder and fill in real values.
#               Do NOT commit '.env' containing real secrets to git.
# ==============================================================================

# Runtime environment ('development', 'test', or 'production')
NODE_ENV=development

# Network port number the Express application listener binds to
PORT=5000

# MongoDB connection URI (e.g. MongoDB Atlas link or local mongodb://localhost:27017/ai-planner)
MONGODB_URI=mongodb://localhost:27017/ai-planner

# Secret key used to sign JWT Access Tokens (use a strong random hex string, e.g. openssl rand -hex 32)
JWT_ACCESS_SECRET=change-me-access-secret-32-character-length-key

# Secret key used to sign JWT Refresh Tokens (should be different from JWT_ACCESS_SECRET)
JWT_REFRESH_SECRET=change-me-refresh-secret-32-character-length-key

# Duration an access token remains active (e.g., '15m' for 15 minutes, '1h' for 1 hour)
JWT_ACCESS_EXPIRES_IN=15m

# Duration a refresh token remains active when 'Remember Me' is unchecked (e.g., '7d' for 7 days)
JWT_REFRESH_EXPIRES_IN=7d

# Duration a refresh token remains active when 'Remember Me' is checked (e.g., '30d' for 30 days)
JWT_REFRESH_EXPIRES_IN_REMEMBER=30d

# Allowed Cross-Origin Resource Sharing (CORS) domains (comma-separated list without trailing slashes)
CORS_ORIGINS=http://localhost:3000

# Domain associated with refresh token HTTP-only cookies (leave blank for localhost/relative cookies in development)
COOKIE_DOMAIN=

# Restrict refresh token cookie transmission to HTTPS connections only ('true' or 'false')
COOKIE_SECURE=false

# Google Gemini AI Console Developer API Key (required to run AI-powered features)
GEMINI_API_KEY=

# Target Gemini Large Language Model identifier (defaults to stable Gemini Flash)
GEMINI_MODEL=gemini-1.5-flash
